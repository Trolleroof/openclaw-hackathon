# Copy to `.env` and fill in real values. Never commit `.env`.
#   cp .env.example .env

# --- Slack (Hermes notifications) ---
# Incoming Webhook URL from your Slack app (https://api.slack.com/apps).
SLACK_WEBHOOK_URL=
SLACK_HERMES_CHANNEL=#general
# Bot User OAuth Token from the Slack app OAuth and Permissions page.
SLACK_BOT_TOKEN=
# Channel ID (e.g. from channel details in Slack client).
SLACK_CHANNEL_ID=

# --- Agentmail ---
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=
AGENTMAIL_API_BASE_URL=https://api.agentmail.to/v0

# Comma-separated list of addresses for run reports.
REPORT_RECIPIENT_EMAIL=

# --- Public URLs ---
HERMES_PUBLIC_BASE_URL=http://localhost:3000
