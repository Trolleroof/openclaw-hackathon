# AgentMail (https://docs.agentmail.to) — all three required for delivery: not "skipped"
# API key from the AgentMail dashboard (create a key with permission to send).
AGENTMAIL_API_KEY=
# Inbox UUID to send from (create an inbox in the dashboard; copy its id).
AGENTMAIL_INBOX_ID=
AGENTMAIL_API_BASE_URL=https://api.agentmail.to/v0
# Email address that should receive run report emails (Hermes routes AgentMail here).
REPORT_RECIPIENT_EMAIL=nikhilprabhu06@gmail.com

HERMES_PUBLIC_BASE_URL=http://localhost:3000
SLACK_HERMES_CHANNEL=#hermes-agent

# Slack Incoming Webhook — posts run lessons to the Hermes bot in #hermes-agent
# Create at: Slack App > Incoming Webhooks > Add New Webhook to Workspace
SLACK_WEBHOOK_URL=
